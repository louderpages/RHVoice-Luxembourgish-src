define downcaseVowel 
[A : a] | [ร : รก] | [ร : รฃ] | [ร : รค] | [ร : ร ] | [ร : รข] | 
[E : e] | [ร : รฉ] |           [ร : รซ] | [ร : รจ] | [ร : รช] | 
