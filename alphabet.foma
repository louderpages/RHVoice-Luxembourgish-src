 ; 


define downcaseLetter 
downcaseVowel | downcaseConsonant ; 

define lcVowelLetter downcaseVowel.l ;
define ucVowelLetter downcaseVowel.u ; 
define lcConsonantLetter downcaseConsonant.l | ร ;  # no uppercase for ร 
define ucConsonantLetter downcaseConsonant.u ; 
define vowelLetter lcVowelLetter | ucVowelLetter ; 
define consonantLetter lcConsonantLetter | ucConsonantLetter ; 
define lcLetter lcVowelLetter | lcConsonantLetter ; 
define ucLetter ucVowelLetter | ucConsonantLetter ; 
define letter vowelLetter | consonantLetter | stressMark ; 
define Letter letter ;

define grapheme letter ; 

# Consonants are doubled after stressed short vowels, unless there are more consonants after. Double k is written ck, double z is written tz.

define doubleConsonantLetter 
{bb} | {ck} | {dd} | {ff} | {kk} | {ll} | {mm} | {nn} | {pp} | {tt} | {tz} ; 

define g2pConsonant 
# Default pronunciation of single consonant letters.
[b^{1,2} : "/b"] | 
[c : "/k"] | 
[d^{1,2} : "/d"] | 
[f^{1,2} : "/f"] | 
# Special symbol for an unresolved g. Later rules will try to figure it out.
[g : "/g?"] | 
[h : "/h"] | 
[j : "/j"] | 
[k^{1,2} : "/k"] | 
[l^{1,2} : "/l"] | 
[m^{1,2} : "/m"] | 
[n^{1,2} : "/n"] | 
[รฑ : ["/n" "/j"]] |
[p^{1,2} : "/p"] | 
[q : "/k"] | 
[r^{1,2} : "/r"] | 
[[s|ร|รง] : "/s"] | 
[t^{1,2} : "/t"] | 
[{th} : "/t"] | 
[v : "/v"] | 
[w^{1,2} : "/v"] | 
[x : ["/k" "/s"]] | 
[[(t) z] : "/ts"] | 
# Pronounced differently when doubled.
[{ss} : "/s"] | 
#Default pronunciation of digraphs and trigraphs.
[{ch} : "/ch"] | 
[{sch} : "/sh"] | 
[{chs} : ["/k" "/s"]] | 
[{ck} : "/k"] | 
[{ng} : "/ng"]  | 
[{nk} : ["/ng" "/k"]] | 
[{gg} : "/g"] 
; 

# Some consonants don't appear in the default mapping.
define pConsonant [g2pConsonant.l & ?] | "/xh" | "/zh" | "/zz" | "/g" | "/rh" |"/ts" | "/dz" | "/z" | "/dzh" | "/th" | "/dh" | "/ch"; 

define g2pShortVowel 
[[a|รฃ|รก|ร |รข] : "/a0"] | 
[รค : "/ae0"] |
# Assume that the single e is most often pronounced as the schwa, but there are a lot of exceptions.
[e : "/ax0"] | 
[รฉ : ["/e0" stressMark]] |
# From the auto-translated spelling manual.
[รซ : ["/ax0" stressMark]] | 
[[i|รฌ|รญ|y] : "/i0"] | 
[o : "/o0"] | 
[[u|รน] : "/u0"] | 
[รผ : "/y0"] | 
[รฏ : "/i0"] | 
[[รฒ|รณ] : "/o0"] | 
[[รต|ล] : "/ooe0"] | 
[รฎ : "/i0"] 
 ; 

define g2pGraphicStressedVowel 
g2pShortVowel .o. [? stressMark] ; 

# A mapping to long vowel phonemes. Most vowel letters can be single or double.
define g2pLongVowel 
[[a (a)] : "/aa0"] | 
[{ee} : "/ee0"] | 
[[i (i)] : "/ii0"] | 
[[o (o)] : "/oo0"] | 
[[u (u)] : "/uu0"] | 
[{รผรผ} : "/yy0"] | 
[{รครค} : "/aae0"] | 
[รจ : "/ee0"] | 
[[รถ (รถ)] : "/ooe0"] | 
[รช : "/aae0"] | 
[ร  : "/aa0"] | 
[รด : "/oo0"] | 
[รป : "/uu0"] | 
[รข : "/aa0"] 
 ; 

# Extract the double mapping from the mapping above.
define g2pDoubleLongVowel 
[vowelLetter^2] .o. g2pLongVowel ; 

define g2pDiphthong 
[[{ai} | {ei}] : "/ai0"] | 
[{au} : "/au0"] | 
[[{รคu} | {eu} | {oy} | {oi}] : "/oi0"] | 
[{ou} : ["/o0" "/w"]] |  # test, g2p v3 
### [{ou} : "/ou0"] | 
[{รฉi} : "/ei0"] | 
[{ie} : "/ie0"] | 
[{ue} : "/ue0"] | 
[{รคi} : "/aei0"]  
 ; 

# According to the spelling guide, the same vowel length related rules apply to these 4 letters.
define vowelLetterGroup1 a | i | o | u ; 
define g2pShortVowelGroup1 vowelLetterGroup1 .o. g2pShortVowel ;
define g2pLongVowelGroup1 vowelLetterGroup1 .o. g2pLongVowel ; 

define g2pVowel 
# Use the priority union to get a single mapping for single a, i, o and u. 
[g2pShortVowel .P. g2pLongVowel] | 
g2pDiphthong ; 

define g2pSingleVowel 
vowelLetter .o. g2pVowel ; 

